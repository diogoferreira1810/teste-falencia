# ── Database ──────────────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Falenica teste
DB_USER=postgres
DB_PASSWORD=safeword

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong random string for production, e.g.:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
